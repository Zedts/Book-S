generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  fullName  String
  phone     String
  role      String   @default("users") // 'admin' atau 'users'
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
